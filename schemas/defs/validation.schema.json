{
  "$schema": "https://json-schema.org/draft/2020-12/schema",

  "$id": "https://editorialafrica.ai/schemas/defs/validation.schema.json",

  "type": "object",

  "properties": {

    "enabled": {
      "type": "boolean"
    },

    "severity": {

      "type": "string",

      "enum": [
        "Information",
        "Warning",
        "Error",
        "Critical"
      ]
    }
  },

  "required": [
    "enabled"
  ],

  "additionalProperties": false
}