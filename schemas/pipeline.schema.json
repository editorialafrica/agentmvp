{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://editorialafrica.ai/schemas/pipeline.schema.json",
  "title": "EditorialAfrica Pipeline Schema",
  "description": "Defines the execution pipeline for the EditorialAfrica AI Platform.",

  "allOf": [
    {
      "$ref": "common.schema.json"
    },
    {
      "type": "object",

      "properties": {
        "pipeline": {
          "type": "string",
          "description": "Pipeline identifier.",
          "minLength": 1
        },

        "description": {
          "type": "string"
        },

        "executionMode": {
          "type": "string",
          "enum": [
            "Sequential",
            "Parallel",
            "Hybrid"
          ]
        },

        "continueOnWarning": {
          "type": "boolean",
          "default": true
        },

        "stopOnError": {
          "type": "boolean",
          "default": true
        },

        "stages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/stage"
          }
        }
      },

      "required": [
        "pipeline",
        "description",
        "executionMode",
        "stages"
      ],

      "additionalProperties": false
    }
  ],

  "$defs": {
    "stage": {
      "type": "object",

      "properties": {
        "name": {
          "type": "string"
        },

        "description": {
          "type": "string"
        },

        "enabled": {
          "type": "boolean"
        },

        "agent": {
          "type": "string"
        },

        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },

        "reads": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },

        "writes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },

        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },

        "retryPolicy": {
          "$ref": "#/$defs/retryPolicy"
        },

        "validation": {
          "$ref": "#/$defs/validation"
        }
      },

      "required": [
        "name",
        "enabled",
        "agent"
      ],

      "additionalProperties": false
    },

    "retryPolicy": {
      "type": "object",

      "properties": {
        "enabled": {
          "type": "boolean"
        },

        "maxRetries": {
          "type": "integer",
          "minimum": 0
        },

        "delaySeconds": {
          "type": "integer",
          "minimum": 0
        }
      },

      "required": [
        "enabled"
      ],

      "additionalProperties": false
    },

    "validation": {
      "type": "object",

      "properties": {
        "enabled": {
          "type": "boolean"
        },

        "severity": {
          "type": "string",
          "enum": [
            "Information",
            "Warning",
            "Error",
            "Critical"
          ]
        }
      },

      "required": [
        "enabled"
      ],

      "additionalProperties": false
    }
  }
}